{
    "version": "@VERSION@",
    "name": "network",
    "requires": {
        "cockpit": "186"
    },

    "menu": {
        "index": {
            "label": "Networking",
            "order": 20,
            "docs": [
                {
                    "label": "Managing networking",
                    "url": "http://knowledgebase.45drives.com/kb/kb045284-managing-networking-in-houston-ui/"
                },
                {
                    "label": "Managing firewall",
                    "url": "http://knowledgebase.45drives.com/kb/kb045285-managing-firewall-in-houston-ui/"
                }
            ],
            "keywords": [
                {
                    "matches": ["network", "interface", "bridge", "vlan", "bond", "team", "port", "mac", "ipv4", "ipv6"]
                },
                {
                    "matches": ["firewall", "firewalld", "zone", "tcp", "udp"],
                    "goto": "/network/firewall"
                }
            ]
        }
    },

    "hacks": {
        "with_networkmanager_needs_root": "@with_networkmanager_needs_root@"
    }
}
