{
    "version": "@VERSION@",
    "name": "system",

    "requires": {
	"cockpit": "122"
    },

    "menu": {
        "index": {
            "label": "Overview",
            "order": 10,
            "docs": [
                {
                    "label": "Contact 45Drives Support",
                    "url": "https://www.45drives.com/support/"
                },
                {
                    "label": "Submitting a Support Ticket to 45Drives",
                    "url": "https://www.45drives.com/support/request/"
                },
                {
                    "label": "Configuring Domain Join",
                    "url": "http://knowledgebase.45drives.com/kb/kb045274-configuring-domain-join-with-houston-ui/"
                },
                {
                    "label": "Configuring Tuned Performance Profiles",
                    "url": "http://knowledgebase.45drives.com/kb/kb045274-configuring-tuned-performance-profiles/"
                }          
            ],
            "keywords": [
                {
                    "matches": ["time", "date", "restart", "shut", "domain", "machine", "operating system", "os", "asset tag", "ssh", "power", "version", "host"]
                },
                {
                    "matches": ["hardware", "mitigation", "pci", "memory", "cpu", "bios", "ram", "dimm", "serial"],
                    "goto": "/system/hwinfo"
                },
                {
                    "matches": ["graphs", "metrics", "history", "pcp", "cpu", "memory", "disks", "network", "cgroups"],
                    "goto": "/metrics"
                }
            ]
        },
        "services": {
            "label": "Services",
            "order": 100,
            "docs": [
                {
                    "label": "Managing services",
                    "url": "http://knowledgebase.45drives.com/kb/kb045276-managing-systemd-services-in-houston-ui/"
                }
            ],
            "keywords": [
                {
                    "matches": ["service", "systemd", "target", "socket", "timer", "path", "unit", "systemctl"]
                },
                {
                    "matches": ["boot", "mask", "unmask", "restart", "enable", "disable"],
                    "weight": 1
                }
            ]
        },
        "logs": {
            "label": "Logs",
            "order": 101,
            "docs": [
                {
                    "label": "Reviewing logs",
                    "url": "http://knowledgebase.45drives.com/kb/kb045277-reviewing-logs-in-houston-ui/"
                }
            ],
            "keywords": [
                {
                    "matches": ["journal", "warning", "error", "debug"]
                },
                {
                    "matches": ["abrt", "crash", "coredump"],
                    "goto": "?tag=abrt-notification"
                }
            ]
        }
    },

    "tools": {
        "terminal": {
            "label": "Terminal",
            "keywords": [
                {
                    "matches": ["console", "command", "bash", "shell"]
                }
            ]
        }
    },

    "preload": [ "index", "services" ],

    "content-security-policy": "img-src 'self' data:"
}
